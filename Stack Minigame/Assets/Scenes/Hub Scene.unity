  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'A Stack is a data structure where items are stored like on a real stack.

    A
    new item gets added to the top, which is also the first to be taken out again.


    It
    follows: Last In, First Out (LIFO)


    - push(): Add an item to the top of
    the stack.

    - pop(): Remove the top item from the stack.k

    - peek():
    Look at the top item without removing it.


    In game:

    push = add ingredient

    pop
    = take ingredient

    peek = check top ingredient'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
